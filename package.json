{
    "name": "blame-annotate",
    "displayName": "Blame Annotate",
    "description": "Display git or svn blame in editor gutter like JetBrains IDEs",
    "version": "0.3.4",
    "publisher": "ashiqi",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/yyqrc/vscode-annotate-blame.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "SCM Providers"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "icon": "logo.png",
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "Blame Annotate",
            "type": "object",
            "properties": {
                "blameAnnotate.svnExecutablePath": {
                    "type": "string",
                    "default": "svn",
                    "description": "Path to svn executable (e.g., 'svn' or 'C:\\Program Files\\SlikSvn\\bin\\svn.exe')"
                }
            }
        },
        "commands": [
            {
                "command": "git.blame.toggle",
                "title": "%command.toggle%"
            },
            {
                "command": "git.blame.show",
                "title": "%command.show.git%"
            },
            {
                "command": "git.blame.show.svn",
                "title": "%command.show.svn%"
            },
            {
                "command": "git.blame.hide",
                "title": "%command.hide%"
            }
        ],
        "menus": {
            "editor/lineNumber/context": [
                {
                    "command": "git.blame.show",
                    "when": "gitblame.showMenuState && gitblame.vcsType == 'git'"
                },
                {
                    "command": "git.blame.show.svn",
                    "when": "gitblame.showMenuState && gitblame.vcsType == 'svn'"
                },
                {
                    "command": "git.blame.hide",
                    "when": "gitblame.hideMenuState"
                }
            ],
            "editor/context": [
                {
                    "command": "git.blame.show",
                    "when": "gitblame.showMenuState && gitblame.vcsType == 'git'",
                    "group": "navigation"
                },
                {
                    "command": "git.blame.show.svn",
                    "when": "gitblame.showMenuState && gitblame.vcsType == 'svn'",
                    "group": "navigation"
                },
                {
                    "command": "git.blame.hide",
                    "when": "gitblame.hideMenuState",
                    "group": "navigation"
                }
            ]
        },
        "keybindings": [
            {
                "command": "git.blame.toggle",
                "key": "ctrl+alt+b",
                "mac": "cmd+alt+b",
                "when": "editorTextFocus"
            },
            {
                "command": "git.blame.hide",
                "key": "escape",
                "when": "editorTextFocus && gitblame.hideMenuState"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "^16.11.7",
        "@typescript-eslint/eslint-plugin": "^5.42.0",
        "@typescript-eslint/parser": "^5.42.0",
        "eslint": "^8.26.0",
        "typescript": "^4.8.4",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2"
    }
}